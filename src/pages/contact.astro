---
import MainLayout from '@/layouts/MainLayout.astro';
import WhatsAppForm from '@/components/jowoland/shared/WhatsAppForm.astro';
import MapEmbed from '@/components/jowoland/shared/MapEmbed.astro';
import { COMPANY, SITE, SOCIAL_LINKS, createWebPageSchema } from '@/data/site';

const pageTitle = `Hubungi ${SITE.title}`;
const metaDescription =
  'Hubungi PT. Jowo Land Construction untuk konsultasi gratis dan penawaran resmi jasa bore pile.';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={pageTitle}
  lang="id"
  structuredData={createWebPageSchema('/contact', pageTitle, metaDescription, 'ContactPage')}
>
  <section
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mx-auto mb-10 max-w-2xl text-center">
      <h1
        class="text-3xl font-bold text-neutral-800 md:text-4xl "
      >
        Hubungi PT. Jowo Land Construction
      </h1>
      <p class="mt-3 text-neutral-600 ">
        Isi formulir di bawah untuk konsultasi gratis. Pesan akan langsung
        dikirim ke WhatsApp kami.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2">
      <WhatsAppForm title="Get in Touch" showProjectFields={true} />

      <div class="space-y-6">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6  ">
          <h2 class="font-bold text-neutral-800 ">
            Informasi Kontak
          </h2>
          <dl class="mt-4 space-y-3 text-sm">
            <div>
              <dt class="text-neutral-500 ">Alamat</dt>
              <dd class="font-medium text-neutral-800 ">
                {COMPANY.address}
              </dd>
            </div>
            <div>
              <dt class="text-neutral-500 ">Telepon / WhatsApp</dt>
              <dd>
                <a
                  href={`https://wa.me/${COMPANY.phoneWa}`}
                  class="font-medium text-green-600 hover:underline"
                  >{COMPANY.phone}</a
                >
              </dd>
            </div>
            <div>
              <dt class="text-neutral-500 ">Email</dt>
              <dd>
                <a
                  href={`mailto:${COMPANY.email}`}
                  class="font-medium text-yellow-600 hover:underline "
                  >{COMPANY.email}</a
                >
              </dd>
            </div>
            <div>
              <dt class="text-neutral-500 ">Jam Operasional</dt>
              <dd class="font-medium text-neutral-800 ">
                {COMPANY.hours}
              </dd>
            </div>
          </dl>
        </div>

        <MapEmbed />

        <div class="rounded-2xl border border-neutral-200 bg-white p-6  ">
          <h2 class="font-bold text-neutral-800 ">
            Sosial Media
          </h2>
          <ul class="mt-3 space-y-2 text-sm">
            {
              Object.entries(SOCIAL_LINKS).map(([key, url]) => (
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="capitalize text-yellow-600 hover:underline "
                  >
                    {key}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
