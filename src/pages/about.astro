---
import MainLayout from '@/layouts/MainLayout.astro';
import SectionHeader from '@/components/jowoland/shared/SectionHeader.astro';
import { aboutContent } from '@/data/about';
import { IMAGES } from '@/data/images';
import { SITE, createWebPageSchema } from '@/data/site';
import { SOCIAL_LINKS } from '@/data/site';

const { meta, title, intro, founder, socialTitle } = aboutContent;
---

<MainLayout
  title={`${meta.title} | ${SITE.title}`}
  customDescription={meta.description}
  customOgTitle={meta.title}
  lang="id"
  structuredData={createWebPageSchema('/about', meta.title, meta.description, 'AboutPage')}
>
  <section
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <SectionHeader title={title} subtitle={intro} />

    <div class="mt-10 overflow-hidden rounded-2xl">
      <img
        src={IMAGES.about}
        alt="Tentang PT. Jowo Land Construction"
        class="h-72 w-full object-cover lg:h-96"
        loading="lazy"
      />
    </div>

    <div
      class="mt-12 grid gap-8 rounded-2xl border border-neutral-200 bg-white p-8 dark:border-neutral-700 dark:bg-neutral-900 lg:grid-cols-[200px_1fr]"
    >
      <div class="mx-auto overflow-hidden rounded-full lg:mx-0">
        <img
          src={IMAGES.founder}
          alt={founder.name}
          class="h-48 w-48 object-cover"
          loading="lazy"
        />
      </div>
      <div>
        <p class="text-sm font-semibold text-yellow-600 dark:text-yellow-400">
          {founder.greeting}
        </p>
        <div class="prose prose-neutral mt-4 max-w-none whitespace-pre-line dark:prose-invert">
          {founder.message}
        </div>
        <div class="mt-6 border-t border-neutral-200 pt-6 dark:border-neutral-700">
          <p class="font-bold text-neutral-800 dark:text-neutral-200">
            {founder.name}
          </p>
          <p class="text-neutral-600 dark:text-neutral-400">{founder.role}</p>
          <p class="text-neutral-600 dark:text-neutral-400">{founder.company}</p>
          <p class="mt-1 text-sm italic text-yellow-600 dark:text-yellow-400">
            "{founder.title}"
          </p>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-200">
        {socialTitle}
      </h2>
      <div class="mt-4 flex flex-wrap justify-center gap-4">
        <a
          href={SOCIAL_LINKS.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="text-yellow-600 hover:underline dark:text-yellow-400"
          >Instagram</a
        >
        <a
          href={SOCIAL_LINKS.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-yellow-600 hover:underline dark:text-yellow-400"
          >Facebook</a
        >
        <a
          href={SOCIAL_LINKS.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="text-yellow-600 hover:underline dark:text-yellow-400"
          >YouTube</a
        >
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-yellow-600 hover:underline dark:text-yellow-400"
          >LinkedIn</a
        >
        <a
          href={SOCIAL_LINKS.tiktok}
          target="_blank"
          rel="noopener noreferrer"
          class="text-yellow-600 hover:underline dark:text-yellow-400"
          >TikTok</a
        >
      </div>
    </div>
  </section>
</MainLayout>
