---
const {
  label = Astro.currentLocale === 'fr' ? 'Me rappeler' : 'Remember me',
  id,
} = Astro.props;

interface Props {
  label?: string;
  id?: string;
}
---

{/* Container for the checkbox and its label */}
<div class="flex items-center">
  {/* Checkbox input */}
  <div class="flex">
    <input
      id={id}
      name="remember-me"
      type="checkbox"
      class="pointer-events-none mt-0.5 shrink-0 rounded-sm border-neutral-200 text-neutral-600 focus:ring-yellow-400     "
    />
  </div>
  {/* Label for the checkbox */}
  <div class="ms-3">
    <label for={id} class="text-sm text-neutral-800 "
      >{label} <slot />
    </label>
  </div>
</div>
