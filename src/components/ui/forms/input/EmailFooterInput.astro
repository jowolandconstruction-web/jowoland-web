---
const {
  label = 'Search',
  title = Astro.currentLocale === 'fr' ? "S'abonner" : 'Subscribe',
  id = 'footer-input',
} = Astro.props;

interface Props {
  label?: string;
  title?: string;
  id?: string;
}

const placeholder =
  Astro.currentLocale === 'fr' ? 'Entrez votre email' : 'Enter your email';
---

<div
  class="mt-4 flex flex-col items-center gap-2 rounded-lg bg-neutral-200 p-2 sm:flex-row sm:gap-3 "
>
  <div class="w-full">
    <label for={id} class="sr-only">{label}</label>
    <input
      type="text"
      id={id}
      name="footer-input"
      class="block w-full rounded-lg border-transparent bg-neutral-100 px-4 py-3 text-sm text-neutral-600 caret-orange-400 focus:border-orange-400 focus:ring-orange-400 disabled:pointer-events-none disabled:opacity-50    "
      placeholder={placeholder}
    />
  </div>
  <a
    class="inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-orange-400 p-3 text-sm font-bold whitespace-nowrap text-neutral-50 ring-zinc-500 outline-hidden transition duration-300 hover:bg-orange-500 focus-visible:ring-3 disabled:pointer-events-none disabled:opacity-50 sm:w-auto   "
    href="#"
  >
    {title}
  </a>
</div>
