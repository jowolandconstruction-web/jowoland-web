---
import type { BlogPost } from '@/lib/wordpress/types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article
  class="group overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition hover:shadow-md  "
>
  <a href={`/blog/${post.slug}`} class="block">
    <div class="aspect-video overflow-hidden">
      <img
        src={post.image}
        alt={post.imageAlt}
        class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
        loading="lazy"
      />
    </div>
    <div class="p-5">
      <time
        datetime={post.date}
        class="text-xs font-medium text-yellow-600 "
      >
        {formattedDate}
      </time>
      <h3
        class="mt-2 text-lg font-bold text-neutral-800 group-hover:text-yellow-600  "
      >
        {post.title}
      </h3>
      <p class="mt-2 line-clamp-3 text-sm text-neutral-600 ">
        {post.excerpt}
      </p>
    </div>
  </a>
</article>
