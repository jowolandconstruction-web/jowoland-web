---
interface Props {
  title: string;
  sections: Array<{
    title: string;
    content?: string;
    subsections?: Array<{ title: string; content: string }>;
  }>;
  lastUpdated: string;
  contact?: {
    title: string;
    company: string;
    address: string;
    phone: string;
    email: string;
  };
  commitment?: string;
}

const { title, sections, lastUpdated, contact, commitment } = Astro.props;
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="mx-auto max-w-3xl">
    <h1
      class="text-3xl font-bold text-neutral-800 md:text-4xl "
    >
      {title}
    </h1>
    <p class="mt-2 text-sm text-neutral-500 ">
      Terakhir diperbarui: {lastUpdated}
    </p>

    <div class="prose prose-neutral mt-10 max-w-none ">
      {
        sections.map(section => (
          <div class="mb-8">
            <h2 class="text-xl font-bold">{section.title}</h2>
            {section.content && <p class="mt-3">{section.content}</p>}
            {section.subsections?.map(sub => (
              <div class="mt-4">
                <h3 class="text-lg font-semibold">{sub.title}</h3>
                <p class="mt-2">{sub.content}</p>
              </div>
            ))}
          </div>
        ))
      }

      {
        contact && (
          <div class="mt-10 rounded-xl border border-neutral-200 p-6 ">
            <h2 class="text-xl font-bold">{contact.title}</h2>
            <p class="mt-3 font-medium">{contact.company}</p>
            <p class="mt-1">{contact.address}</p>
            <p class="mt-1">
              WhatsApp:{' '}
              <a href={`https://wa.me/6285280749218`}>{contact.phone}</a>
            </p>
            <p class="mt-1">
              Email:{' '}
              <a href={`mailto:${contact.email}`}>{contact.email}</a>
            </p>
          </div>
        )
      }

      {commitment && <p class="mt-8 font-medium italic">{commitment}</p>}
    </div>
  </div>
</section>
