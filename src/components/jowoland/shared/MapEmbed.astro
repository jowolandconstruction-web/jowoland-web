---
import { COMPANY } from '@/data/site';

interface Props {
  height?: string;
}

const { height = '400' } = Astro.props;
---

<div class="overflow-hidden rounded-2xl border border-neutral-200 " id="map-container">
  <!-- Placeholder: Click to load map -->
  <button
    id="map-placeholder"
    class="flex w-full flex-col items-center justify-center gap-3 bg-neutral-100 px-6 py-12 text-center "
    style={`height: ${height}px;`}
  >
    <svg class="h-12 w-12 text-yellow-600 " fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    <div>
      <p class="font-bold text-neutral-800 ">Lokasi Kantor</p>
      <p class="text-sm text-neutral-600  mt-1">Klik untuk melihat peta</p>
    </div>
  </button>

  <!-- Actual map iframe (hidden until clicked) -->
  <iframe
    id="map-iframe"
    class="hidden w-full"
    width="100%"
    height={height}
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="Lokasi PT. Jowo Land Construction"></iframe>
</div>

<p class="mt-3 text-sm text-neutral-600 ">
  <a
    href={COMPANY.mapsUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="font-medium text-yellow-600 hover:underline "
  >
    Buka di Google Maps →
  </a>
</p>

<script is:inline define:vars={{ mapsEmbed: COMPANY.mapsEmbed }}>
  const placeholder = document.getElementById('map-placeholder');
  const iframe = document.getElementById('map-iframe');
  const container = document.getElementById('map-container');

  placeholder?.addEventListener('click', () => {
    iframe.src = mapsEmbed;
    iframe.classList.remove('hidden');
    placeholder.classList.add('hidden');
  });
</script>
