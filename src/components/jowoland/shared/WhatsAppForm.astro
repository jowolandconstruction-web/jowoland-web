---
import { COMPANY } from '@/data/site';

interface Props {
  title?: string;
  submitLabel?: string;
  showProjectFields?: boolean;
}

const {
  title = 'Dapatkan Penawaran Harga Bore Pile',
  submitLabel = 'Kirim via WhatsApp',
  showProjectFields = true,
} = Astro.props;

const formId = `wa-form-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-900 sm:p-8">
  <h3 class="mb-6 text-xl font-bold text-neutral-800 dark:text-neutral-200">
    {title}
  </h3>

  <form id={formId} class="grid gap-4">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label
          for={`${formId}-name`}
          class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-300"
          >Nama Lengkap</label
        >
        <input
          type="text"
          id={`${formId}-name`}
          name="name"
          required
          class="block w-full rounded-lg border border-neutral-300 px-4 py-3 text-sm focus:border-yellow-500 focus:ring-yellow-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-200"
          placeholder="Nama Anda"
        />
      </div>
      <div>
        <label
          for={`${formId}-phone`}
          class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-300"
          >Nomor WhatsApp</label
        >
        <input
          type="tel"
          id={`${formId}-phone`}
          name="phone"
          required
          class="block w-full rounded-lg border border-neutral-300 px-4 py-3 text-sm focus:border-yellow-500 focus:ring-yellow-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-200"
          placeholder="08xx xxxx xxxx"
        />
      </div>
    </div>

    {
      showProjectFields && (
        <>
          <div>
            <label
              for={`${formId}-location`}
              class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-300"
            >
              Lokasi Proyek
            </label>
            <input
              type="text"
              id={`${formId}-location`}
              name="location"
              class="block w-full rounded-lg border border-neutral-300 px-4 py-3 text-sm focus:border-yellow-500 focus:ring-yellow-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-200"
              placeholder="Kota / Kabupaten"
            />
          </div>
          <div>
            <label
              for={`${formId}-project`}
              class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-300"
            >
              Jenis Proyek / Detail
            </label>
            <textarea
              id={`${formId}-project`}
              name="project"
              rows={6}
              class="block w-full rounded-lg border border-neutral-300 px-4 py-3 text-sm focus:border-yellow-500 focus:ring-yellow-500 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-200"
              placeholder="Contoh: Rumah 2 lantai, diameter 30cm, estimasi 29 titik..."
            />
          </div>
        </>
      )
    }

    <button
      type="submit"
      class="inline-flex items-center justify-center gap-2 rounded-lg bg-yellow-600 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-yellow-200 transition hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:ring-offset-2 dark:shadow-yellow-900/30"
    >
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.882 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        ></path>
      </svg>
      {submitLabel}
    </button>

    <p class="text-center text-sm text-neutral-500 dark:text-neutral-400">
      Respon Cepat via WhatsApp 24 Jam
    </p>
  </form>
</div>

<script is:inline define:vars={{ formId, phoneWa: COMPANY.phoneWa }}>
  const form = document.getElementById(formId);

  form?.addEventListener('submit', e => {
    e.preventDefault();

    const data = new FormData(form);
    const name = data.get('name') || '';
    const phone = data.get('phone') || '';
    const location = data.get('location') || '';
    const project = data.get('project') || '';

    const message = [
      'Halo PT. Jowo Land Construction,',
      '',
      `Nama: ${name}`,
      `WhatsApp: ${phone}`,
      location ? `Lokasi Proyek: ${location}` : '',
      project ? `Detail Proyek: ${project}` : '',
      '',
      'Mohon info penawaran harga bore pile. Terima kasih.',
    ]
      .filter(Boolean)
      .join('\n');

    const url = `https://wa.me/${phoneWa}?text=${encodeURIComponent(message)}`;
    window.open(url, '_blank');
  });
</script>
