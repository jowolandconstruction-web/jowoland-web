---
import { serviceAreas } from '@/data/home/pricing-why';
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="mx-auto mb-8 max-w-3xl text-center">
    <h2
      class="text-2xl font-bold text-neutral-800 md:text-4xl dark:text-neutral-200"
    >
      Area Layanan
    </h2>
    <p class="mt-3 text-neutral-600 dark:text-neutral-400">
      Melayani proyek pondasi bore pile di berbagai wilayah di Indonesia.
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-3">
    {
      serviceAreas.map(area => (
        <span class="rounded-full border border-yellow-300 bg-yellow-50 px-5 py-2 text-sm font-semibold text-yellow-800 dark:border-yellow-700 dark:bg-yellow-900/20 dark:text-yellow-300">
          {area}
        </span>
      ))
    }
  </div>
</section>
