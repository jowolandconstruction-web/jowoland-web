---
import type { PortfolioProject } from '@/lib/wordpress/types';
import PortfolioCard from '@/components/jowoland/portfolio/PortfolioCard.astro';
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import { COMPANY } from '@/data/site';

interface Props {
  projects: PortfolioProject[];
  limit?: number;
  showExpand?: boolean;
}

const { projects, limit = 4, showExpand = true } = Astro.props;
const displayed = projects.slice(0, limit);
---

<section
  class="bg-neutral-100 px-4 py-10 sm:px-6 lg:px-8 lg:py-14 dark:bg-neutral-900/50"
>
  <div class="mx-auto max-w-[85rem] 2xl:max-w-full">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <h2
        class="text-2xl font-bold text-neutral-800 md:text-4xl dark:text-neutral-200"
      >
        Dokumentasi dan Portofolio Proyek
      </h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-400">
        Bukti pekerjaan nyata dari berbagai proyek pondasi bore pile di seluruh
        Indonesia.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {displayed.map(project => <PortfolioCard project={project} />)}
    </div>

    {
      showExpand && projects.length > limit && (
        <div class="mt-8 text-center">
          <SecondaryCTA title="Lihat Semua Portofolio" url="/portfolio" />
        </div>
      )
    }
  </div>
</section>
