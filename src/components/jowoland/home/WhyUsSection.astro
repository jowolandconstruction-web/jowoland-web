---
import { whyUsContent } from '@/data/home/pricing-why';
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  <div class="mx-auto mb-10 max-w-3xl text-center">
    <h2
      class="text-2xl font-bold text-neutral-800 md:text-4xl "
    >
      {whyUsContent.title}
    </h2>
    {
      whyUsContent.intro.map(p => (
        <p class="mt-4 text-pretty text-neutral-600 ">
          {p}
        </p>
      ))
    }
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {
      whyUsContent.items.map(item => (
        <div class="rounded-2xl border border-neutral-200 bg-white p-6  ">
          <h3 class="text-lg font-bold text-neutral-800 ">
            {item.title}
          </h3>
          {item.content.map(p => (
            <p class="mt-3 text-pretty text-neutral-600 ">
              {p}
            </p>
          ))}
          {item.standards && (
            <ul class="mt-4 space-y-2">
              {item.standards.map(std => (
                <li class="rounded-lg bg-neutral-50 p-3 ">
                  <span class="font-semibold text-yellow-600 ">
                    {std.code}
                  </span>
                  <span class="text-neutral-600 ">
                    {' '}
                    — {std.name}
                  </span>
                </li>
              ))}
            </ul>
          )}
          {item.closingNote && (
            <p class="mt-4 text-sm font-medium italic text-neutral-700 ">
              {item.closingNote}
            </p>
          )}
        </div>
      ))
    }
  </div>
</section>
