---
import WhatsAppForm from '@/components/jowoland/shared/WhatsAppForm.astro';
import MapEmbed from '@/components/jowoland/shared/MapEmbed.astro';
import { closingContent } from '@/data/home/pricing-why';
import { COMPANY, SOCIAL_LINKS } from '@/data/site';
---

<section
  class="bg-neutral-100 px-4 py-10 sm:px-6 lg:px-8 lg:py-14 "
  id="hubungi-kami"
>
  <div class="mx-auto max-w-[85rem] 2xl:max-w-full">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <p class="text-pretty text-neutral-600 ">
        {closingContent.text}
      </p>
      <h2
        class="mt-6 text-2xl font-bold text-neutral-800 md:text-3xl "
      >
        {closingContent.ctaTitle}
      </h2>
      <p class="mt-3 text-neutral-600 ">
        {closingContent.ctaText}
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2">
      <WhatsAppForm />

      <div class="space-y-6">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6  ">
          <h3 class="font-bold text-neutral-800 ">
            Alamat Kantor Pusat
          </h3>
          <p class="mt-2 text-neutral-600 ">
            {COMPANY.address}
          </p>
          <p class="mt-2 text-neutral-600 ">
            {COMPANY.phone} · {COMPANY.hours}
          </p>
        </div>

        <MapEmbed />

        <div class="rounded-2xl border border-neutral-200 bg-white p-6  ">
          <h3 class="font-bold text-neutral-800 ">
            Sosial Media
          </h3>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a
                href={SOCIAL_LINKS.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="text-yellow-600 hover:underline "
                >Instagram</a
              >
            </li>
            <li>
              <a
                href={SOCIAL_LINKS.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="text-yellow-600 hover:underline "
                >Facebook</a
              >
            </li>
            <li>
              <a
                href={SOCIAL_LINKS.youtube}
                target="_blank"
                rel="noopener noreferrer"
                class="text-yellow-600 hover:underline "
                >YouTube</a
              >
            </li>
            <li>
              <a
                href={SOCIAL_LINKS.tiktok}
                target="_blank"
                rel="noopener noreferrer"
                class="text-yellow-600 hover:underline "
                >TikTok</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
