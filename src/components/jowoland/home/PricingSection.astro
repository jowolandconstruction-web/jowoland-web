---
import {
  pricingContent,
  pricingTable,
  pricingSimulations,
} from '@/data/home/pricing-why';
---

<section
  id="harga"
  class="bg-neutral-100 px-4 py-10 sm:px-6 lg:px-8 lg:py-14 "
>
  <div class="mx-auto max-w-[85rem] 2xl:max-w-full">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <h2
        class="text-2xl font-bold text-neutral-800 md:text-4xl "
      >
        {pricingContent.title}
      </h2>
    </div>

    <div class="mb-12 rounded-2xl border border-neutral-200 bg-white p-6   sm:p-8">
      <h3 class="text-xl font-bold text-neutral-800 ">
        {pricingContent.introTitle}
      </h3>
      {
        pricingContent.intro.map(p => (
          <p class="mt-3 text-pretty text-neutral-600 ">
            {p}
          </p>
        ))
      }

      <h4 class="mt-8 font-bold text-neutral-800 ">
        {pricingContent.comparisonTitle}
      </h4>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {
          pricingContent.comparisonPoints.map(point => (
            <li class="flex items-center gap-2 text-neutral-600 ">
              <span class="text-yellow-600">→</span>
              {point}
            </li>
          ))
        }
      </ul>

      <div
        class="mt-8 rounded-xl bg-yellow-50 p-5 "
      >
        <h4 class="font-bold text-neutral-800 ">
          {pricingContent.investmentNote.title}
        </h4>
        {
          pricingContent.investmentNote.content.map(p => (
            <p class="mt-2 text-pretty text-neutral-600 ">
              {p}
            </p>
          ))
        }
      </div>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-neutral-200 bg-white  ">
      <table class="min-w-full divide-y divide-neutral-200 ">
        <thead class="bg-yellow-500/10">
          <tr>
            {
              pricingTable.headers.map(header => (
                <th
                  scope="col"
                  class="px-6 py-4 text-left text-sm font-bold text-neutral-800 "
                >
                  {header}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-200 ">
          {
            pricingTable.rows.map(row => (
              <tr class="hover:bg-neutral-50 ">
                <td class="px-6 py-4 font-medium text-neutral-800 ">
                  {row.diameter}
                </td>
                <td class="px-6 py-4 text-neutral-600 ">
                  {row.miniCrane}
                </td>
                <td class="px-6 py-4 text-neutral-600 ">
                  {row.excavator}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-12">
      <h3 class="text-xl font-bold text-neutral-800 ">
        {pricingContent.priceFactorsTitle}
      </h3>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          pricingContent.priceFactors.map(factor => (
            <div class="rounded-xl border border-neutral-200 p-4 ">
              <h4 class="font-semibold text-neutral-800 ">
                {factor.title}
              </h4>
              <p class="mt-2 text-sm text-neutral-600 ">
                {factor.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-12">
      <h3 class="mb-6 text-xl font-bold text-neutral-800 ">
        Simulasi Perhitungan & Analisa Harga Satuan Pekerjaan Bored Pile
      </h3>
      <div class="grid gap-6 md:grid-cols-2">
        {
          pricingSimulations.map(sim => (
            <div class="rounded-2xl border border-neutral-200 bg-white p-6  ">
              <h4 class="text-lg font-bold text-yellow-600 ">
                {sim.title}
              </h4>
              <dl class="mt-4 space-y-2">
                {sim.specs.map(spec => (
                  <div class="flex justify-between text-sm">
                    <dt class="text-neutral-500 ">
                      {spec.label}
                    </dt>
                    <dd class="font-medium text-neutral-800 ">
                      {spec.value}
                    </dd>
                  </div>
                ))}
              </dl>
              <p class="mt-4 rounded-lg bg-neutral-50 p-3 text-sm font-medium ">
                {sim.calculation}
              </p>
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-center text-sm text-neutral-500 ">
        Ini hanya simulasi. Untuk angka pasti, harus disesuaikan kondisi proyek.
      </p>
    </div>
  </div>
</section>
